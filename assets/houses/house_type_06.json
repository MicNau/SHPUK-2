  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",
      "constraints": {
        "area": {
          "min": 70,
          "max": 140,
          "step": 5,
          "default": 90,
          "unit": "m2"
        },
        "floor_h": {
          "min": 270,
          "max": 330,
          "step": 10,
          "default": 300,
          "unit": "cm"
        }
      },
      "vars": {
        "_comment": "L,W — bbox; bh — высота top/bot прямоугольника; offX — смещение между ними. Реальная площадь меньше bbox на 2*offX*bh",
        "L": "sqrt(area * 2.6)",
        "W": "sqrt(area * 1.15)",
        "offX": "L * 0.33",
        "bh": "W * 0.40"
      },
      "perimeter": [
        {
          "_comment": "═══ Верх: верхняя стена top-блока (run = L-offX) → ═══"
        },
        {
          "run": "L - offX",
          "facade": "auto_windows",
          "window_type": "wide",
          "min_margin": 1.0
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Правая стенка top-блока (run = bh) ↓ ═══"
        },
        {
          "run": "bh",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Низ правой части top-блока (run = offX) ← ═══"
        },
        {
          "run": "offX",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "single"
            },
            {
              "wall": 1.2
            },
            {
              "window": "single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: вход в connector + bot-блок"
        },
        {
          "_comment": "═══ Правая стенка connector + bot-блока (run = W-bh) ↓ ═══"
        },
        {
          "run": "W - bh",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "door": "single"
            },
            {
              "wall": "fill"
            },
            {
              "window": "double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Низ bot-блока (run = L-offX) ← ═══"
        },
        {
          "run": "L - offX",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "double"
            },
            {
              "wall": 0.5
            },
            {
              "door": "double",
              "main": true
            },
            {
              "wall": 0.5
            },
            {
              "window": "double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Левая стенка bot-блока (run = bh) ↑ ═══"
        },
        {
          "run": "bh",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "wide"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Верх левой части bot-блока (run = offX) → ═══"
        },
        {
          "run": "offX",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "door": "slide_double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: вход в connector + top-блок"
        },
        {
          "_comment": "═══ Левая стенка connector + top-блока (run = W-bh) ↑ ═══"
        },
        {
          "run": "W - bh",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "wide"
            },
            {
              "wall": "fill"
            },
            {
              "door": "slide_single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        }
      ]
    }
