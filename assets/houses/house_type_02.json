{
  "id": "type_02",
  "name": "Одноэтажный с двускатной крышей",
  "description": "Прямоугольный одноэтажный дом, двускатная крыша, конёк по длинной оси",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 80,  "unit": "cm" },
    "roof_angle":     { "min": 20, "max": 40,  "step": 5,  "default": 30,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "gable",

  "modules": {
    "_comment": "Spec v2: размеры — range-объекты {min, max, default} в метрах",

    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",

      "constraints": {
        "area":    { "min": 50, "max": 120, "step": 5,  "default": 90,  "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },

      "vars": {
        "L": "sqrt(area * 1.6)",
        "W": "sqrt(area / 1.6)"
      },

      "perimeter": [
        { "_comment": "═══ Северная стена (длинная, 2 двойных + 1 single) → ═══" },
        {
          "run": "L",
          "facade": [
            { "wall": 0.8 },
            { "window": "double" },
            { "wall": "fill" },
            { "window": "single" },
            { "wall": "fill" },
            { "window": "double" },
            { "wall": 0.8 }
          ]
        },
        { "turn": 90 },

        { "_comment": "═══ Восточная стена (короткая, вход) ↓ ═══" },
        {
          "run": "W",
          "facade": [
            { "wall": "fill" },
            { "door": "single" },
            { "wall": "fill" }
          ]
        },
        { "turn": 90 },

        { "_comment": "═══ Южная стена (длинная, авто-окна) ← ═══" },
        {
          "run": "L",
          "facade": "auto_windows",
          "window_type": "single",
          "min_margin": 1.0
        },
        { "turn": 90 },

        { "_comment": "═══ Западная стена (короткая, авто-окна) ↑ ═══" },
        {
          "run": "W",
          "facade": "auto_windows",
          "window_type": "single",
          "min_margin": 0.8
        },
        { "turn": 90 }
      ]
    }
  ],

  "materials_map": {
    "mat_wall":  { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":  { "label": "Цоколь",             "swappable": true  },
    "mat_roof":  { "label": "Крыша",              "swappable": true  },
    "mat_frame": { "label": "Рамы окон",          "swappable": true  },
    "mat_glass": { "label": "Стекло",             "swappable": false },
    "mat_door":  { "label": "Дверь",              "swappable": true  }
  }
}
