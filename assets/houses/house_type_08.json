  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",
      "constraints": {
        "_comment": "min=60: дальше двор становится слишком мал для slide_double на внутренней стене",
        "area": {
          "min": 60,
          "max": 140,
          "step": 5,
          "default": 95,
          "unit": "m2"
        },
        "floor_h": {
          "min": 270,
          "max": 330,
          "step": 10,
          "default": 300,
          "unit": "cm"
        }
      },
      "vars": {
        "_comment": "L,W — bbox; ringW — толщина стены-кольца вокруг двора; slit — ширина прохода во двор на южной стене",
        "L": "sqrt(area * 1.4)",
        "W": "sqrt(area / 1.4)",
        "ringW": "sqrt(area) * 0.20",
        "slit": "1.0"
      },
      "perimeter": [
        {
          "_comment": "═══ N: внешняя северная стена (вся длина L) → ═══"
        },
        {
          "run": "L",
          "facade": "auto_windows",
          "window_type": "wide",
          "min_margin": 1.0
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ E: внешняя восточная стена (вся высота W) ↓ ═══"
        },
        {
          "run": "W",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "single"
            },
            {
              "wall": 0.5
            },
            {
              "door": "onehalf"
            },
            {
              "wall": 0.5
            },
            {
              "window": "single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ S правая часть: между outer SE и входом в слит ← ═══"
        },
        {
          "run": "L/2 - slit/2",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Слит, правая стенка прохода (внутрь, к двору) ↑ ═══"
        },
        {
          "run": "ringW",
          "facade": [
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Двор, S-стена правая часть (от слита до inner SE) → ═══"
        },
        {
          "run": "L/2 - slit/2 - ringW",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: inner SE — внутренний угол двора (1/4)"
        },
        {
          "_comment": "═══ Двор, E-стена (раздвижная одностворчатая во двор) ↑ ═══"
        },
        {
          "run": "W - 2*ringW",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "door": "slide_single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: inner NE (2/4)"
        },
        {
          "_comment": "═══ Двор, N-стена (две панорамы во двор) ← ═══"
        },
        {
          "run": "L - 2*ringW",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "wide"
            },
            {
              "wall": 0.5
            },
            {
              "window": "wide"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: inner NW (3/4)"
        },
        {
          "_comment": "═══ Двор, W-стена (раздвижная двойная во двор) ↓ ═══"
        },
        {
          "run": "W - 2*ringW",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "door": "slide_double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": -90,
          "_comment": "REFLEX: inner SW (4/4)"
        },
        {
          "_comment": "═══ Двор, S-стена левая часть (от inner SW до слита) → ═══"
        },
        {
          "run": "L/2 - slit/2 - ringW",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ Слит, левая стенка прохода (наружу из двора) ↓ ═══"
        },
        {
          "run": "ringW",
          "facade": [
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ S левая часть: от выхода из слита до outer SW ← ═══"
        },
        {
          "run": "L/2 - slit/2",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "door": "single"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        },
        {
          "_comment": "═══ W: внешняя западная стена ↑ ═══"
        },
        {
          "run": "W",
          "facade": [
            {
              "wall": "fill"
            },
            {
              "window": "double"
            },
            {
              "wall": 0.5
            },
            {
              "door": "double"
            },
            {
              "wall": 0.5
            },
            {
              "window": "double"
            },
            {
              "wall": "fill"
            }
          ]
        },
        {
          "turn": 90
        }
      ]
    }
