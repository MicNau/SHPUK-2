{
  "id": "type_10",
  "name": "1.5-этажный (мансарда)",
  "description": "Первый этаж — большой прямоугольник, второй этаж — меньший, центрированный сверху. На выступающих частях 1-го этажа — плоская терраса/кровля. Hip-крыша на втором этаже.",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 80,  "unit": "cm" },
    "roof_angle":     { "min": 15, "max": 35,  "step": 5,  "default": 25,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "hip",

  "modules": {
    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",

      "constraints": {
        "area":    { "min": 70, "max": 140, "step": 5,  "default": 100, "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },

      "vars": {
        "L1": "sqrt(area * 1.5)",
        "W1": "sqrt(area / 1.5)"
      },

      "perimeter": [
        { "_comment": "═══ N: длинная стена →" },
        { "run": "L1", "facade": "auto_windows", "window_type": "double", "min_margin": 1.0 },
        { "turn": 90 },

        { "_comment": "═══ E: короткая (вход) ↓" },
        { "run": "W1", "facade": [
          { "wall": "fill" },
          { "door": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ S: длинная стена ←" },
        { "run": "L1", "facade": "auto_windows", "window_type": "single", "min_margin": 1.0 },
        { "turn": 90 },

        { "_comment": "═══ W: короткая стена ↑" },
        { "run": "W1", "facade": "auto_windows", "window_type": "single", "min_margin": 0.8 },
        { "turn": 90 }
      ]
    },
    {
      "id": "floor_2",
      "label": "Второй этаж (мансарда)",
      "_comment": "Второй этаж = 50% площади первого, центрирован внутри L1×W1.",

      "constraints": {
        "floor_h": { "min": 240, "max": 300, "step": 10, "default": 260, "unit": "cm" }
      },

      "vars": {
        "_comment": "L1/W1 — размер 1-го этажа (тот же area). L2/W2 — половина по площади. ox/oz — центрирование.",
        "L1": "sqrt(area * 1.5)",
        "W1": "sqrt(area / 1.5)",
        "L2": "sqrt(area * 0.5 * 1.5)",
        "W2": "sqrt(area * 0.5 / 1.5)",
        "ox": "(L1 - L2) / 2",
        "oz": "(W1 - W2) / 2"
      },

      "start_offset": { "x": "ox", "z": "oz" },

      "perimeter": [
        { "_comment": "═══ N: верхняя стена 2-го этажа →" },
        { "run": "L2", "facade": "auto_windows", "window_type": "single", "min_margin": 0.8 },
        { "turn": 90 },

        { "_comment": "═══ E ↓" },
        { "run": "W2", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ S ←" },
        { "run": "L2", "facade": "auto_windows", "window_type": "single", "min_margin": 0.8 },
        { "turn": 90 },

        { "_comment": "═══ W ↑" },
        { "run": "W2", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 }
      ]
    }
  ],

  "features": {
    "cornice": true,
    "inter_floor_cornice": true
  },

  "materials_map": {
    "mat_wall":    { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":    { "label": "Цоколь",             "swappable": true  },
    "mat_roof":    { "label": "Крыша",              "swappable": true  },
    "mat_cornice": { "label": "Карнизы",            "swappable": true  },
    "mat_frame":   { "label": "Рамы окон",          "swappable": true  },
    "mat_glass":   { "label": "Стекло",             "swappable": false },
    "mat_door":    { "label": "Дверь",              "swappable": true  }
  }
}
