{
  "id": "type_10",
  "name": "1.5-этажный (мансарда)",
  "description": "Один этаж с мансардой под gable-крышей. Жилое пространство мансарды — под наклонными скатами, низкая вертикальная стенка (knee wall) над верхом основного этажа.",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 80,  "unit": "cm" },
    "roof_angle":     { "min": 30, "max": 60,  "step": 5,  "default": 45,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "mansard",

  "mansard": {
    "knee_height":  0.20,
    "lower_angle":  70,
    "upper_angle":  25,
    "lower_height": 2.20
  },

  "modules": {
    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    },
    "dormer": {
      "w":     { "min": 1.00, "max": 2.50, "default": 1.50 },
      "h":     { "min": 1.00, "max": 2.00, "default": 1.40 },
      "depth": { "min": 0.60, "max": 1.50, "default": 1.00 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_dormer.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",

      "constraints": {
        "area":    { "min": 70, "max": 140, "step": 5,  "default": 100, "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },

      "vars": {
        "L1": "sqrt(area * 1.5)",
        "W1": "sqrt(area / 1.5)"
      },

      "perimeter": [
        { "_comment": "═══ N: длинная стена →" },
        { "run": "L1", "facade": "auto_windows", "window_type": "double", "min_margin": 1.0 },
        { "turn": 90 },

        { "_comment": "═══ E: короткая (вход) ↓" },
        { "run": "W1", "facade": [
          { "wall": "fill" },
          { "door": "single", "main": true },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ S: длинная стена ←" },
        { "run": "L1", "facade": "auto_windows", "window_type": "single", "min_margin": 1.0 },
        { "turn": 90 },

        { "_comment": "═══ W: короткая стена ↑" },
        { "run": "W1", "facade": "auto_windows", "window_type": "single", "min_margin": 0.8 },
        { "turn": 90 }
      ]
    }
  ],

  "features": {
    "chimney":  { "position": [0.7, 0.5], "model": "chimney" },
    "cornice":  true
  },

  "materials_map": {
    "mat_wall":    { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":    { "label": "Цоколь",             "swappable": true  },
    "mat_roof":    { "label": "Крыша",              "swappable": true  },
    "mat_cornice": { "label": "Карнизы",            "swappable": true  },
    "mat_frame":   { "label": "Рамы окон",          "swappable": true  },
    "mat_glass":   { "label": "Стекло",             "swappable": false },
    "mat_door":    { "label": "Дверь",              "swappable": true  }
  }
}
