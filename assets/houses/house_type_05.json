{
  "id": "type_05",
  "name": "Т-образный дом",
  "description": "План в форме Т: широкая верхняя перекладина + 2 ноги вниз с двором между ними. 2 reflex-угла.",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 70,  "unit": "cm" },
    "roof_angle":     { "min": 15, "max": 35,  "step": 5,  "default": 22,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "hip",

  "modules": {
    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "window_wide": {
      "w": { "min": 1.80, "max": 3.00, "default": 2.40 },
      "h": { "min": 0.80, "max": 2.00, "default": 1.50 },
      "y": { "min": 0.20, "max": 1.20, "default": 0.70 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v", "h"],
      "glb": "mod_window_wide.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    },
    "door_double": {
      "w": { "min": 1.20, "max": 1.80, "default": 1.40 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 2,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_double.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",
      "constraints": {
        "area":    { "min": 70, "max": 140, "step": 5,  "default": 100, "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },
      "vars": {
        "_comment": "L,W — bbox; bh — высота перекладины; leg_w — ширина каждой ноги",
        "L":     "sqrt(area * 1.6)",
        "W":     "sqrt(area / 1.6)",
        "bh":    "W * 0.45",
        "leg_w": "L * 0.28"
      },
      "perimeter": [
        { "_comment": "═══ N: верхняя стена перекладины (панорама гостиной) →" },
        { "run": "L", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" },
          { "window": "wide" },
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ E: правая внешняя стена ↓" },
        { "run": "W", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Низ правой ноги ←" },
        { "run": "leg_w", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: внешний угол двора" },

        { "_comment": "═══ Внутренняя стена правой ноги ↑" },
        { "run": "W - bh", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Под перекладиной: широкое окно во двор ←" },
        { "run": "L - 2*leg_w", "facade": [
          { "wall": "fill" },
          { "window": "wide" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Внутренняя стена левой ноги ↓" },
        { "run": "W - bh", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: внешний угол двора" },

        { "_comment": "═══ Низ левой ноги ←" },
        { "run": "leg_w", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ W: левая внешняя стена (главный вход) ↑" },
        { "run": "W", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": 0.6 },
          { "door": "double", "main": true },
          { "wall": 0.6 },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 }
      ]
    }
  ],

  "features": {
    "chimney":  { "position": [0.5, 0.4], "model": "chimney" },
    "cornice":  true,
    "gutters":  true,
    "downpipe": true,
    "porch": {
      "width": 1.8,
      "depth": 1.4,
      "has_canopy": true,
      "canopy_height": 2.30,
      "canopy_slope": 0.10,
      "has_railing": true,
      "railing_height": 0.95
    }
  },

  "materials_map": {
    "mat_wall":           { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":           { "label": "Цоколь",             "swappable": true  },
    "mat_roof":           { "label": "Крыша",              "swappable": true  },
    "mat_soffit":         { "label": "Подшивка свеса",     "swappable": true  },
    "mat_frame":          { "label": "Рамы окон",          "swappable": true  },
    "mat_glass":          { "label": "Стекло",             "swappable": false },
    "mat_door":           { "label": "Двери",              "swappable": true  },
    "mat_cornice":        { "label": "Карнизы",            "swappable": true  },
    "mat_metal":          { "label": "Водосток",           "swappable": true  },
    "mat_porch_step":     { "label": "Ступени крыльца",    "swappable": true  },
    "mat_porch_deck":     { "label": "Проступи крыльца",   "swappable": true  },
    "mat_porch_column":   { "label": "Колонны крыльца",    "swappable": true  },
    "mat_porch_canopy":   { "label": "Навес крыльца",      "swappable": true  },
    "mat_porch_railing":  { "label": "Перила крыльца",     "swappable": true  }
  }
}
