{
  "id": "type_04",
  "name": "Крестообразный дом",
  "description": "План-крест: центральный квадрат + 4 коротких выступа. Верхний — парадный вход, нижний — служебный.",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 70,  "unit": "cm" },
    "roof_angle":     { "min": 15, "max": 35,  "step": 5,  "default": 22,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "hip",

  "modules": {
    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "window_wide": {
      "w": { "min": 1.80, "max": 3.00, "default": 2.40 },
      "h": { "min": 0.80, "max": 2.00, "default": 1.50 },
      "y": { "min": 0.20, "max": 1.20, "default": 0.70 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v", "h"],
      "glb": "mod_window_wide.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    },
    "door_double": {
      "w": { "min": 1.20, "max": 1.80, "default": 1.40 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 2,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_double.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",
      "constraints": {
        "area":    { "min": 80, "max": 160, "step": 5,  "default": 110, "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },
      "vars": {
        "_comment": "aw — ширина руки (большая); ext_x/ext_z — длина рук (короткие)",
        "L":     "sqrt(area * 1.2)",
        "W":     "sqrt(area / 1.2)",
        "aw":    "sqrt(area) * 0.50",
        "ext_x": "(L - aw) / 2",
        "ext_z": "(W - aw) / 2"
      },
      "perimeter": [
        { "_comment": "═══ ВЕРХНЯЯ РУКА: торец (вход парадный) →" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": 0.5 },
          { "door": "double", "main": true },
          { "wall": 0.5 },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Правая стенка верхней руки ↓" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход верхняя→правая рука" },

        { "_comment": "═══ Верх правой руки →" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Торец правой руки ↓" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "window": "wide" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Низ правой руки ←" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход правая→нижняя рука" },

        { "_comment": "═══ Правая стенка нижней руки ↓" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Торец нижней руки (служебный вход) ←" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": 0.4 },
          { "door": "single" },
          { "wall": 0.4 },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Левая стенка нижней руки ↑" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход нижняя→левая рука" },

        { "_comment": "═══ Низ левой руки ←" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Торец левой руки ↑" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "window": "wide" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Верх левой руки →" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход левая→верхняя рука" },

        { "_comment": "═══ Левая стенка верхней руки ↑" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 }
      ]
    }
  ],

  "features": {
    "chimney":  { "position": [0.5, 0.5], "model": "chimney" },
    "cornice":  true,
    "gutters":  true,
    "downpipe": true,
    "porch": {
      "width": 1.8,
      "depth": 1.4,
      "has_canopy": true,
      "canopy_height": 2.30,
      "canopy_slope": 0.10,
      "has_railing": true,
      "railing_height": 0.95
    }
  },

  "materials_map": {
    "mat_wall":           { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":           { "label": "Цоколь",             "swappable": true  },
    "mat_roof":           { "label": "Крыша",              "swappable": true  },
    "mat_soffit":         { "label": "Подшивка свеса",     "swappable": true  },
    "mat_frame":          { "label": "Рамы окон",          "swappable": true  },
    "mat_glass":          { "label": "Стекло",             "swappable": false },
    "mat_door":           { "label": "Двери",              "swappable": true  },
    "mat_cornice":        { "label": "Карнизы",            "swappable": true  },
    "mat_metal":          { "label": "Водосток",           "swappable": true  },
    "mat_porch_step":     { "label": "Ступени крыльца",    "swappable": true  },
    "mat_porch_deck":     { "label": "Проступи крыльца",   "swappable": true  },
    "mat_porch_column":   { "label": "Колонны крыльца",    "swappable": true  },
    "mat_porch_canopy":   { "label": "Навес крыльца",      "swappable": true  },
    "mat_porch_railing":  { "label": "Перила крыльца",     "swappable": true  }
  }
}
