{
  "id": "type_04",
  "name": "Крестообразный дом",
  "description": "План в форме креста: центральный квадрат + 4 руки. 4 reflex-угла. Showcase всех 8 типов окон/дверей.",

  "constraints": {
    "base_h":         { "min": 50, "max": 120, "step": 10, "default": 70,  "unit": "cm" },
    "roof_angle":     { "min": 15, "max": 35,  "step": 5,  "default": 22,  "unit": "deg" },
    "wall_thickness": 0.25,
    "pillar_size":    0.25
  },

  "roof_type": "hip",

  "modules": {
    "_comment": "Все 8 параметрических типов проёмов: 3 окна + 5 дверей",

    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "window_wide": {
      "w": { "min": 1.80, "max": 3.00, "default": 2.40 },
      "h": { "min": 0.80, "max": 2.00, "default": 1.50 },
      "y": { "min": 0.20, "max": 1.20, "default": 0.60 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v", "h"],
      "glb": "mod_window_wide.glb"
    },

    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    },
    "door_onehalf": {
      "w": { "min": 1.10, "max": 1.40, "default": 1.20 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1.5,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_onehalf.glb"
    },
    "door_double": {
      "w": { "min": 1.20, "max": 1.80, "default": 1.40 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 2,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_double.glb"
    },
    "door_slide_single": {
      "w": { "min": 0.80, "max": 1.20, "default": 1.00 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "slide",
      "frame_profile": 0.05,
      "glb": "mod_door_slide_single.glb"
    },
    "door_slide_double": {
      "w": { "min": 1.40, "max": 3.00, "default": 2.00 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.30 },
      "y": 0.00,
      "leaves": 2,
      "mechanism": "slide",
      "frame_profile": 0.05,
      "glb": "mod_door_slide_double.glb"
    }
  },

  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",

      "constraints": {
        "_comment": "min=75: при меньшей площади руки креста не вмещают showcase из 8 модулей (slide_double 2.0 + walls на торце руки)",
        "area":    { "min": 75, "max": 140, "step": 5,  "default": 90,  "unit": "m2" },
        "floor_h": { "min": 270, "max": 330, "step": 10, "default": 300, "unit": "cm" }
      },

      "vars": {
        "_comment": "L,W — bbox креста; aw — толщина руки; ext_x/ext_z — длина горизонтальной/вертикальной рук",
        "L":     "sqrt(area * 1.4)",
        "W":     "sqrt(area / 1.4)",
        "aw":    "sqrt(area) * 0.35",
        "ext_x": "(L - aw) / 2",
        "ext_z": "(W - aw) / 2"
      },

      "perimeter": [
        { "_comment": "═══ ВЕРХНЯЯ РУКА: торец T (run=aw) → парадный вход (door_double) ═══" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "door": "double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Правая стенка верхней руки (run=ext_z) → одиночное окно ═══" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход верхняя→правая рука" },

        { "_comment": "═══ Верх правой руки (run=ext_x) → панорамные окна (single+double) ═══" },
        { "run": "ext_x", "facade": [
          { "wall": 0.4 },
          { "window": "double" },
          { "wall": "fill" },
          { "window": "single" },
          { "wall": 0.4 }
        ]},
        { "turn": 90 },

        { "_comment": "═══ ПРАВАЯ РУКА: торец R (run=aw) → выход на террасу (slide_double) ═══" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "door": "slide_double" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Низ правой руки (run=ext_x) → широкое окно ═══" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "wide" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход правая→нижняя рука" },

        { "_comment": "═══ Правая стенка нижней руки (run=ext_z) → одиночное окно ═══" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ НИЖНЯЯ РУКА: торец B (run=aw) → служебный вход (door_single) ═══" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "door": "single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Левая стенка нижней руки (run=ext_z) → одиночное окно ═══" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход нижняя→левая рука" },

        { "_comment": "═══ Низ левой руки (run=ext_x) → авто-окна single ═══" },
        { "run": "ext_x", "facade": "auto_windows", "window_type": "single", "min_margin": 0.7 },
        { "turn": 90 },

        { "_comment": "═══ ЛЕВАЯ РУКА: торец L (run=aw) → раздвижная одинарная (slide_single) ═══" },
        { "run": "aw", "facade": [
          { "wall": "fill" },
          { "door": "slide_single" },
          { "wall": "fill" }
        ]},
        { "turn": 90 },

        { "_comment": "═══ Верх левой руки (run=ext_x) → парные окна (double+single) ═══" },
        { "run": "ext_x", "facade": [
          { "wall": "fill" },
          { "window": "double" },
          { "wall": 0.4 },
          { "window": "single" },
          { "wall": "fill" }
        ]},
        { "turn": -90, "_comment": "REFLEX: переход левая→верхняя рука" },

        { "_comment": "═══ Левая стенка верхней руки (run=ext_z) → дверь полуторная (onehalf) ═══" },
        { "run": "ext_z", "facade": [
          { "wall": "fill" },
          { "door": "onehalf" },
          { "wall": "fill" }
        ]},
        { "turn": 90 }
      ]
    }
  ],

  "materials_map": {
    "mat_wall":  { "label": "Стены (штукатурка)", "swappable": true  },
    "mat_base":  { "label": "Цоколь",             "swappable": true  },
    "mat_roof":  { "label": "Крыша (парапет)",    "swappable": true  },
    "mat_frame": { "label": "Рамы окон",          "swappable": true  },
    "mat_glass": { "label": "Стекло",             "swappable": false },
    "mat_door":  { "label": "Двери",              "swappable": true  }
  }
}
