{
  "id": "type_simple_gable_white",
  "name": "Простой дом с двускатной крышей",
  "description": "Одноэтажный дом со светлыми стенами, каменным фундаментом и двускатной крышей",
  "constraints": {
    "base_h": { "min": 80, "max": 150, "step": 10, "default": 100, "unit": "cm" },
    "roof_angle": { "min": 30, "max": 50, "step": 5, "default": 40, "unit": "deg" },
    "wall_thickness": 0.20,
    "pillar_size": 0.20
  },
  "roof_type": "gable",
  "modules": {
    "window_single": {
      "w": { "min": 0.60, "max": 1.40, "default": 0.90 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "glb": "mod_window_single.glb"
    },
    "window_double": {
      "w": { "min": 1.00, "max": 2.00, "default": 1.40 },
      "h": { "min": 0.60, "max": 1.80, "default": 1.20 },
      "y": { "min": 0.30, "max": 1.50, "default": 0.90 },
      "frame_profile": 0.05,
      "sill_overhang": 0.03,
      "mullions": ["v"],
      "glb": "mod_window_double.glb"
    },
    "door_single": {
      "w": { "min": 0.80, "max": 1.00, "default": 0.90 },
      "h": { "min": 2.00, "max": 2.40, "default": 2.10 },
      "y": 0.00,
      "leaves": 1,
      "mechanism": "swing",
      "frame_profile": 0.05,
      "glb": "mod_door_single.glb"
    }
  },
  "floors": [
    {
      "id": "floor_1",
      "label": "Первый этаж",
      "constraints": {
        "area": { "min": 60, "max": 120, "step": 5, "default": 90, "unit": "m2" },
        "floor_h": { "min": 280, "max": 320, "step": 10, "default": 300, "unit": "cm" }
      },
      "vars": {
        "L": "sqrt(area * 1.6)",
        "W": "sqrt(area / 1.6)"
      },
      "perimeter": [
        {
          "run": "L",
          "facade": [
            { "wall": "fill" }
          ]
        },
        { "turn": 90 },
        {
          "run": "W",
          "facade": [
            { "wall": "fill" },
            { "window": "double" },
            { "wall": "fill" }
          ]
        },
        { "turn": 90 },
        {
          "run": "L",
          "facade": [
            { "wall": "fill" },
            { "window": "double" },
            { "wall": "fill" },
            { "door": "single", "main": true },
            { "wall": "fill" }
          ]
        },
        { "turn": 90 },
        {
          "run": "W",
          "facade": [
            { "wall": "fill" },
            { "window": "double" },
            { "wall": "fill" },
            { "window": "double" },
            { "wall": "fill" }
          ]
        },
        { "turn": 90 }
      ]
    }
  ],
  "roof_windows": [],
  "features": {
    "gutters": true,
    "cornice": true
  },
  "materials_map": {
    "mat_wall": { "label": "Белые стены", "swappable": true },
    "mat_base": { "label": "Серый фундамент", "swappable": true },
    "mat_roof": { "label": "Коричневая кровля", "swappable": true },
    "mat_frame": { "label": "Деревянные рамы", "swappable": true },
    "mat_door": { "label": "Деревянная дверь", "swappable": true }
  }
}
